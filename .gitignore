yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*.store
.DS_Store
Thumbs.db

# Ambiente
.env
.env.local
.env.*.local
.env.production
.env.development

